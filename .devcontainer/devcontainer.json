{
  "name": "FoodXchange Development",
  "dockerComposeFile": "../docker-compose.yml",
  "service": "web",
  "workspaceFolder": "/app",
  
  "customizations": {
    "vscode": {
      "settings": {
        "python.defaultInterpreterPath": "/usr/local/bin/python",
        "python.linting.enabled": true,
        "python.linting.pylintEnabled": true,
        "python.formatting.provider": "black",
        "python.testing.pytestArgs": [
          "tests"
        ],
        "python.testing.unittestEnabled": false,
        "python.testing.pytestEnabled": true,
        "editor.formatOnSave": true,
        "files.insertFinalNewline": true,
        "files.trimTrailingWhitespace": true,
        "[python]": {
          "editor.codeActionsOnSave": {
            "source.organizeImports": true
          }
        }
      },
      
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "ms-azuretools.vscode-docker",
        "ms-vscode.azurecli",
        "ms-toolsai.jupyter",
        "mtxr.sqltools",
        "mtxr.sqltools-driver-pg",
        "redhat.vscode-yaml",
        "esbenp.prettier-vscode",
        "dbaeumer.vscode-eslint",
        "ms-vscode.azure-account",
        "ms-azuretools.vscode-azurefunctions",
        "eamodio.gitlens",
        "mhutchie.git-graph",
        "donjayamanne.githistory",
        "github.copilot"
      ]
    }
  },
  
  "forwardPorts": [8000, 5432, 6379, 8080],
  
  "postCreateCommand": "pip install -r requirements.txt && pip install --no-deps -e . 2>/dev/null || true",
  
  "postStartCommand": "echo '🚀 FoodXchange development container ready!'",
  
  "remoteUser": "root",
  
  "mounts": [
    "source=${localWorkspaceFolder}/.env,target=/app/.env,type=bind,consistency=cached"
  ],
  
  "features": {
    "ghcr.io/devcontainers/features/git:1": {},
    "ghcr.io/devcontainers/features/azure-cli:1": {},
    "ghcr.io/devcontainers/features/github-cli:1": {}
  }
}