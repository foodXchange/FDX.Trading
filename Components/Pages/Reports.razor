@page "/reports"

<PageTitle>Reports - FoodXchange</PageTitle>

<div class="reports-container">
    <div class="page-header">
        <h1>Business Reports</h1>
        <div class="header-actions">
            <button class="btn btn-primary">Generate Report</button>
            <button class="btn btn-outline">Export Data</button>
        </div>
    </div>
    
    <div class="reports-grid">
        <div class="report-card">
            <div class="report-header">
                <h3>Sales Overview</h3>
                <span class="report-period">Last 30 days</span>
            </div>
            <div class="report-chart">
                <!-- Chart placeholder -->
                <div class="chart-placeholder">📊 Sales Chart</div>
            </div>
            <div class="report-stats">
                <div class="stat">
                    <span class="stat-value">$125,430</span>
                    <span class="stat-label">Total Revenue</span>
                </div>
                <div class="stat">
                    <span class="stat-value">+12%</span>
                    <span class="stat-label">Growth</span>
                </div>
            </div>
        </div>
        
        <div class="report-card">
            <div class="report-header">
                <h3>Contract Performance</h3>
                <span class="report-period">This quarter</span>
            </div>
            <div class="report-chart">
                <div class="chart-placeholder">📈 Contract Chart</div>
            </div>
            <div class="report-stats">
                <div class="stat">
                    <span class="stat-value">47</span>
                    <span class="stat-label">Contracts Signed</span>
                </div>
                <div class="stat">
                    <span class="stat-value">92%</span>
                    <span class="stat-label">Completion Rate</span>
                </div>
            </div>
        </div>
        
        <div class="report-card">
            <div class="report-header">
                <h3>Supplier Analysis</h3>
                <span class="report-period">Current month</span>
            </div>
            <div class="report-chart">
                <div class="chart-placeholder">🏢 Supplier Chart</div>
            </div>
            <div class="report-stats">
                <div class="stat">
                    <span class="stat-value">89</span>
                    <span class="stat-label">Active Suppliers</span>
                </div>
                <div class="stat">
                    <span class="stat-value">4.8</span>
                    <span class="stat-label">Avg Rating</span>
                </div>
            </div>
        </div>
    </div>
    
    <div class="recent-reports">
        <h2>Recent Reports</h2>
        <div class="report-list">
            <div class="report-item">
                <div class="report-info">
                    <h4>Monthly Sales Report</h4>
                    <p>Generated on March 15, 2024</p>
                </div>
                <div class="report-actions">
                    <button class="btn btn-sm btn-outline">Download PDF</button>
                    <button class="btn btn-sm btn-link">View</button>
                </div>
            </div>
        </div>
    </div>
</div>