      "presentation": {
        "echo": true,
        "reveal": "always",
        "panel": "new"
      }
    },
    {
      "label": "Python: Lint Code",
      "type": "shell",
      "command": "flake8 foodxchange/",
      "group": "test",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "panel": "new"
      }
    },
    {
      "label": "Database: Backup",
      "type": "shell",
      "command": "docker exec foodxchange_web_1 python -c \"from foodxchange.database import backup_database; backup_database()\"",
      "group": "build",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "panel": "new"
      }
    },
    {
      "label": "Security: Audit",
      "type": "shell",
      "command": "python -m bandit -r foodxchange/",
      "group": "test",
      "presentation": {
        "echo": true,
        "reveal": "always",
        "panel": "new"
      }
    }
  ]
} 