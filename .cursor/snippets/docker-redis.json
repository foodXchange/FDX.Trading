{
  "Docker Compose Service": {
    "prefix": "dcs",
    "body": [
      "${1:service_name}:",
      "  image: ${2:image_name}",
      "  ports:",
      "    - \"${3:host_port}:${4:container_port}\"",
      "  volumes:",
      "    - ${5:volume_mapping}",
      "  environment:",
      "    - ${6:ENV_VAR}=${7:value}",
      "  depends_on:",
      "    - ${8:dependency}",
      "  restart: unless-stopped"
    ],
    "description": "Docker Compose service template"
  },
  
  "Redis Connection": {
    "prefix": "redis-conn",
    "body": [
      "import redis",
      "",
      "redis_client = redis.Redis(",
      "    host='${1:localhost}',",
      "    port=${2:6379},",
      "    decode_responses=True,",
      "    health_check_interval=30",
      ")",
      "",
      "# Test connection",
      "try:",
      "    redis_client.ping()",
      "    print('✅ Redis connected')",
      "except redis.ConnectionError:",
      "    print('❌ Redis connection failed')"
    ],
    "description": "Redis connection setup"
  },
  
  "Redis Cache Function": {
    "prefix": "redis-cache",
    "body": [
      "def cache_analysis_result(image_hash, analysis_data, ttl=3600):",
      "    \"\"\"Cache AI analysis result in Redis\"\"\"",
      "    cache_key = f'analysis:{image_hash}'",
      "    redis_client.setex(",
      "        cache_key,",
      "        ttl,",
      "        json.dumps(analysis_data)",
      "    )",
      "",
      "def get_cached_analysis(image_hash):",
      "    \"\"\"Get cached analysis result\"\"\"",
      "    cache_key = f'analysis:{image_hash}'",
      "    cached = redis_client.get(cache_key)",
      "    return json.loads(cached) if cached else None"
    ],
    "description": "Redis caching functions for FoodXchange"
  },
  
  "Docker Health Check": {
    "prefix": "docker-health",
    "body": [
      "HEALTHCHECK --interval=${1:30s} --timeout=${2:10s} --start-period=${3:5s} --retries=${4:3} \\",
      "    CMD ${5:curl -f http://localhost:8000/health || exit 1}"
    ],
    "description": "Docker health check"
  },
  
  "FastAPI Endpoint": {
    "prefix": "fastapi-endpoint",
    "body": [
      "@app.${1:get}('/${2:endpoint}')",
      "async def ${3:function_name}(${4:request: Request}):",
      "    \"\"\"${5:Endpoint description}\"\"\"",
      "    try:",
      "        ${6:# Your logic here}",
      "        return {\"status\": \"success\", \"data\": ${7:result}}",
      "    except Exception as e:",
      "        logger.error(f\"Error in ${3:function_name}: {str(e)}\")",
      "        raise HTTPException(status_code=500, detail=\"Internal server error\")"
    ],
    "description": "FastAPI endpoint template"
  },
  
  "SQLAlchemy Model": {
    "prefix": "sqlalchemy-model",
    "body": [
      "class ${1:ModelName}(Base):",
      "    __tablename__ = '${2:table_name}'",
      "",
      "    id = Column(Integer, primary_key=True, index=True)",
      "    created_at = Column(DateTime, default=datetime.utcnow)",
      "    updated_at = Column(DateTime, default=datetime.utcnow, onupdate=datetime.utcnow)",
      "    ${3:# Add your fields here}",
      "",
      "    def __repr__(self):",
      "        return f\"<${1:ModelName}(id={self.id})>\""
    ],
    "description": "SQLAlchemy model template"
  },
  
  "Pydantic Schema": {
    "prefix": "pydantic-schema",
    "body": [
      "class ${1:SchemaName}(BaseModel):",
      "    ${2:field_name}: ${3:str}",
      "    ${4:optional_field}: Optional[${5:str}] = None",
      "",
      "    class Config:",
      "        from_attributes = True",
      "        json_encoders = {",
      "            datetime: lambda v: v.isoformat()",
      "        }"
    ],
    "description": "Pydantic schema template"
  },
  
  "Docker Multi-stage": {
    "prefix": "docker-multi",
    "body": [
      "# Build stage",
      "FROM python:${1:3.11}-slim as builder",
      "",
      "WORKDIR /app",
      "COPY requirements.txt .",
      "RUN pip install --no-cache-dir --user -r requirements.txt",
      "",
      "# Production stage",
      "FROM python:${1:3.11}-slim",
      "",
      "WORKDIR /app",
      "COPY --from=builder /root/.local /root/.local",
      "COPY . .",
      "",
      "ENV PATH=/root/.local/bin:$PATH",
      "EXPOSE ${2:8000}",
      "",
      "CMD [\"${3:uvicorn}\", \"${4:main:app}\", \"--host\", \"0.0.0.0\", \"--port\", \"${2:8000}\"]"
    ],
    "description": "Docker multi-stage build template"
  },
  
  "Redis Session": {
    "prefix": "redis-session",
    "body": [
      "def create_user_session(user_id: int, session_data: dict, ttl: int = 3600):",
      "    \"\"\"Create user session in Redis\"\"\"",
      "    session_key = f'session:{user_id}'",
      "    redis_client.setex(",
      "        session_key,",
      "        ttl,",
      "        json.dumps(session_data)",
      "    )",
      "    return session_key",
      "",
      "def get_user_session(user_id: int):",
      "    \"\"\"Get user session from Redis\"\"\"",
      "    session_key = f'session:{user_id}'",
      "    session_data = redis_client.get(session_key)",
      "    return json.loads(session_data) if session_data else None",
      "",
      "def delete_user_session(user_id: int):",
      "    \"\"\"Delete user session from Redis\"\"\"",
      "    session_key = f'session:{user_id}'",
      "    redis_client.delete(session_key)"
    ],
    "description": "Redis session management functions"
  }
} 