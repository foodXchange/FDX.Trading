# Production Environment Variables for FoodXchange
# These will be set as Azure App Service environment variables

# Application Settings
ENVIRONMENT=production
DEBUG=False
SECRET_KEY=your-production-secret-key-here

# Database Configuration (SQLite for now, can upgrade to PostgreSQL later)
DATABASE_URL=sqlite:///production.db

# Redis Configuration (In-memory for now, can upgrade to Azure Redis later)
REDIS_URL=redis://localhost:6379

# Azure Services (keep your existing ones)
AZURE_OPENAI_API_KEY=${AZURE_OPENAI_API_KEY}
AZURE_OPENAI_ENDPOINT=${AZURE_OPENAI_ENDPOINT}
AZURE_SEARCH_ENDPOINT=${AZURE_SEARCH_ENDPOINT}
AZURE_SEARCH_API_KEY=${AZURE_SEARCH_API_KEY}

# Email Configuration (Use production email service)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=${MAIL_USERNAME}
MAIL_PASSWORD=${MAIL_PASSWORD}

# Domain Configuration
DOMAIN=fdx.trading
BASE_URL=https://www.fdx.trading

# Security Settings
SECURE_SSL_REDIRECT=True
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True