@page "/admin/diagnostics"
@using System.Net.Http.Json
@inject IHttpClientFactory HttpFactory
@rendermode InteractiveServer

@* [Authorize(Roles="admin")] uncomment after auth is configured *@

<PageTitle>System Diagnostics</PageTitle>

<div class="diagnostics-container">
    <h1>System Diagnostics</h1>

    <div class="diagnostics-grid">
        <section class="diagnostic-card">
            <h2>Database (Azure SQL)</h2>
            @if (Db is null)
            {
                <p class="loading">Loading...</p>
            }
            else if (!Db.ok)
            {
                <p><StatusBadge Ok="false" Label="Down" /> @(Db.error ?? "Could not verify database.")</p>
            }
            else
            {
                <ul class="diagnostic-info">
                    <li><strong>Status:</strong> <StatusBadge Ok="true" Label="Up" /></li>
                    <li><strong>Database:</strong> @Db.database</li>
                    <li><strong>Authenticated As:</strong> @Db.authenticatedAs</li>
                    <li><strong>Latency:</strong> @Db.latencyMs ms</li>
                    <li class="server-version"><strong>Server:</strong> @Db.serverVersion</li>
                    <li><strong>UTC:</strong> @Db.utc.ToString("yyyy-MM-dd HH:mm:ss")</li>
                </ul>
            }
            <button class="btn" @onclick="RefreshDb">Refresh</button>
        </section>

        <section class="diagnostic-card">
            <h2>Azure OpenAI</h2>
            @if (Ai is null)
            {
                <p class="loading">Loading...</p>
            }
            else if (!Ai.ok)
            {
                <p><StatusBadge Ok="false" Label="Down" /> @(Ai.error ?? "Not configured or ping failed.")</p>
            }
            else
            {
                <ul class="diagnostic-info">
                    <li><strong>Status:</strong> <StatusBadge Ok="true" Label="Up" /></li>
                    <li><strong>Model:</strong> @Ai.model</li>
                    <li><strong>Latency:</strong> @Ai.latencyMs ms</li>
                    <li><strong>UTC:</strong> @Ai.utc.ToString("yyyy-MM-dd HH:mm:ss")</li>
                </ul>
            }
            <button class="btn" @onclick="RefreshAi">Refresh</button>
        </section>
    </div>

    <div class="diagnostic-card health-check">
        <h2>Health Check Status</h2>
        @if (HealthStatus is null)
        {
            <p class="loading">Loading...</p>
        }
        else
        {
            <p>Endpoint: <code>/health</code></p>
            <p>Status: <StatusBadge Ok="@(HealthStatus == "Healthy")" Label="@HealthStatus" /></p>
        }
        <button class="btn" @onclick="RefreshHealth">Refresh</button>
    </div>
</div>

<style>
    .diagnostics-container {
        padding: 2rem;
        max-width: 1200px;
        margin: 0 auto;
    }

    .diagnostics-container h1 {
        font-size: 1.875rem;
        font-weight: 600;
        margin-bottom: 2rem;
        color: #1f2937;
    }

    .diagnostics-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(400px, 1fr));
        gap: 1.5rem;
        margin-bottom: 1.5rem;
    }

    .diagnostic-card {
        padding: 1.5rem;
        border: 1px solid #e5e7eb;
        border-radius: 0.75rem;
        background: white;
        box-shadow: 0 1px 3px 0 rgba(0, 0, 0, 0.1);
    }

    .diagnostic-card h2 {
        font-size: 1.125rem;
        font-weight: 600;
        margin-bottom: 1rem;
        color: #374151;
    }

    .diagnostic-info {
        list-style: none;
        padding: 0;
        margin: 0 0 1rem 0;
    }

    .diagnostic-info li {
        line-height: 1.8;
        padding: 0.25rem 0;
        border-bottom: 1px solid #f3f4f6;
    }

    .diagnostic-info li:last-child {
        border-bottom: none;
    }

    .server-version {
        word-break: break-word;
        overflow-wrap: anywhere;
    }

    .loading {
        color: #6b7280;
        font-style: italic;
    }

    .btn {
        padding: 0.5rem 1rem;
        border: 1px solid #d1d5db;
        border-radius: 0.375rem;
        background: white;
        color: #374151;
        font-size: 0.875rem;
        font-weight: 500;
        cursor: pointer;
        transition: all 0.15s;
    }

    .btn:hover {
        background: #f9fafb;
        border-color: #9ca3af;
    }

    .btn:active {
        background: #f3f4f6;
    }

    code {
        padding: 0.125rem 0.25rem;
        background: #f3f4f6;
        border-radius: 0.25rem;
        font-family: 'Courier New', monospace;
        font-size: 0.875rem;
    }

    .health-check {
        background: #fafafa;
    }
</style>

@code {
    record DbStatus(bool ok, long latencyMs, string serverVersion, string database, string? authenticatedAs, DateTimeOffset utc, string? error);
    record AiStatus(bool ok, long latencyMs, string model, DateTimeOffset utc, string? error);

    DbStatus? Db;
    AiStatus? Ai;
    string? HealthStatus;

    protected override async Task OnInitializedAsync()
    {
        await LoadAllStatuses();
    }

    async Task LoadAllStatuses()
    {
        var client = HttpFactory.CreateClient("api");
        
        // Load DB status
        try
        {
            Db = await client.GetFromJsonAsync<DbStatus>("/db/verify");
        }
        catch (Exception ex)
        {
            Db = new DbStatus(false, 0, "", "", "", DateTimeOffset.UtcNow, ex.Message);
        }

        // Load AI status
        try
        {
            Ai = await client.GetFromJsonAsync<AiStatus>("/ai/status");
        }
        catch (HttpRequestException)
        {
            // AI endpoint might not exist if not configured
            Ai = new AiStatus(false, 0, "", DateTimeOffset.UtcNow, "Azure OpenAI not configured");
        }
        catch (Exception ex)
        {
            Ai = new AiStatus(false, 0, "", DateTimeOffset.UtcNow, ex.Message);
        }

        // Load health status
        try
        {
            var response = await client.GetAsync("/health");
            HealthStatus = response.IsSuccessStatusCode ? "Healthy" : "Unhealthy";
        }
        catch
        {
            HealthStatus = "Unreachable";
        }
    }

    async Task RefreshDb()
    {
        Db = null;
        StateHasChanged();
        
        var client = HttpFactory.CreateClient("api");
        try
        {
            Db = await client.GetFromJsonAsync<DbStatus>("/db/verify");
        }
        catch (Exception ex)
        {
            Db = new DbStatus(false, 0, "", "", "", DateTimeOffset.UtcNow, ex.Message);
        }
    }

    async Task RefreshAi()
    {
        Ai = null;
        StateHasChanged();
        
        var client = HttpFactory.CreateClient("api");
        try
        {
            Ai = await client.GetFromJsonAsync<AiStatus>("/ai/status");
        }
        catch (HttpRequestException)
        {
            Ai = new AiStatus(false, 0, "", DateTimeOffset.UtcNow, "Azure OpenAI not configured");
        }
        catch (Exception ex)
        {
            Ai = new AiStatus(false, 0, "", DateTimeOffset.UtcNow, ex.Message);
        }
    }

    async Task RefreshHealth()
    {
        HealthStatus = null;
        StateHasChanged();
        
        var client = HttpFactory.CreateClient("api");
        try
        {
            var response = await client.GetAsync("/health");
            HealthStatus = response.IsSuccessStatusCode ? "Healthy" : "Unhealthy";
        }
        catch
        {
            HealthStatus = "Unreachable";
        }
    }
}