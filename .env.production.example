# FoodXchange Production Environment Configuration
# Copy this file to .env.production and update with production values
# SECURITY: Never commit actual production values to git!

# Environment
ENVIRONMENT=production
DEBUG=False

# Database (PostgreSQL) - Use strong passwords
DATABASE_URL=postgresql://foodxchange:${DB_PASSWORD_PROD}@db:5432/foodxchange_prod
DB_HOST=db
DB_PORT=5432
DB_NAME=foodxchange_prod
DB_USER=foodxchange
DB_PASSWORD=${DB_PASSWORD_PROD}

# Redis - Use password in production
REDIS_URL=redis://:${REDIS_PASSWORD_PROD}@redis:6379/0
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=${REDIS_PASSWORD_PROD}

# Application
SECRET_KEY=${SECRET_KEY_PROD}
APP_HOST=0.0.0.0
APP_PORT=8000
USE_HTTPS=True

# Security
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
CORS_ORIGINS=["https://foodxchange.com", "https://www.foodxchange.com"]
ALLOWED_HOSTS=["foodxchange.com", "www.foodxchange.com"]

# Azure Services
AZURE_OPENAI_ENDPOINT=${AZURE_OPENAI_ENDPOINT}
AZURE_OPENAI_KEY=${AZURE_OPENAI_KEY}
AZURE_OPENAI_API_VERSION=2024-08-01-preview
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4
AZURE_OPENAI_VISION_DEPLOYMENT=gpt-4o

# Azure Computer Vision
AZURE_VISION_ENDPOINT=${AZURE_VISION_ENDPOINT}
AZURE_VISION_KEY=${AZURE_VISION_KEY}

# Azure Document Intelligence
AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT=${AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT}
AZURE_DOCUMENT_INTELLIGENCE_KEY=${AZURE_DOCUMENT_INTELLIGENCE_KEY}

# Azure Cognitive Search
AZURE_SEARCH_ENDPOINT=${AZURE_SEARCH_ENDPOINT}
AZURE_SEARCH_KEY=${AZURE_SEARCH_KEY}
AZURE_SEARCH_INDEX=products

# Azure Storage
AZURE_STORAGE_CONNECTION_STRING=${AZURE_STORAGE_CONNECTION_STRING}
AZURE_STORAGE_CONTAINER=product-images

# Email Configuration
SMTP_HOST=${SMTP_HOST}
SMTP_PORT=${SMTP_PORT}
SMTP_USERNAME=${SMTP_USERNAME}
SMTP_PASSWORD=${SMTP_PASSWORD}
SMTP_FROM=noreply@foodxchange.com

# Monitoring
SENTRY_DSN=${SENTRY_DSN_PROD}
LOG_LEVEL=WARNING
LOG_FORMAT=json

# Feature Flags
ENABLE_RATE_LIMITING=True
ENABLE_CACHING=True
ENABLE_ANALYTICS=True

# File Upload
MAX_UPLOAD_SIZE=10485760  # 10MB in bytes
ALLOWED_EXTENSIONS=jpg,jpeg,png,webp,pdf

# Rate Limiting (stricter in production)
RATE_LIMIT_DEFAULT=60
RATE_LIMIT_WINDOW=3600

# Session
SESSION_LIFETIME=86400  # 24 hours in seconds
SESSION_SECURE=True  # HTTPS only

# Workers
WEB_CONCURRENCY=4
WORKER_CONNECTIONS=1000