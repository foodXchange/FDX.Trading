# FoodXchange Staging Environment Configuration
# Copy this file to .env.staging and update with staging values

# Environment
ENVIRONMENT=staging
DEBUG=False

# Database (PostgreSQL) - Use strong passwords
DATABASE_URL=postgresql://foodxchange:${DB_PASSWORD_STAGING}@db:5432/foodxchange_staging
DB_HOST=db
DB_PORT=5432
DB_NAME=foodxchange_staging
DB_USER=foodxchange
DB_PASSWORD=${DB_PASSWORD_STAGING}

# Redis - Use password in staging
REDIS_URL=redis://:${REDIS_PASSWORD_STAGING}@redis:6379/0
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=${REDIS_PASSWORD_STAGING}

# Application
SECRET_KEY=${SECRET_KEY_STAGING}
APP_HOST=0.0.0.0
APP_PORT=8000
USE_HTTPS=True

# Security
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
CORS_ORIGINS=["https://staging.foodxchange.com"]
ALLOWED_HOSTS=["staging.foodxchange.com", "localhost"]

# Azure Services (same as production)
AZURE_OPENAI_ENDPOINT=${AZURE_OPENAI_ENDPOINT}
AZURE_OPENAI_KEY=${AZURE_OPENAI_KEY}
AZURE_OPENAI_API_VERSION=2024-08-01-preview
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4
AZURE_OPENAI_VISION_DEPLOYMENT=gpt-4o

# Other Azure services...
# (Copy from .env.example and use same values as production)

# Monitoring
SENTRY_DSN=${SENTRY_DSN_STAGING}
LOG_LEVEL=INFO
LOG_FORMAT=json

# Feature Flags
ENABLE_RATE_LIMITING=True
ENABLE_CACHING=True
ENABLE_ANALYTICS=True

# Workers
WEB_CONCURRENCY=2
WORKER_CONNECTIONS=500