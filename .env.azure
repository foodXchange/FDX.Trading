# FoodXchange Azure Production Environment Configuration
# This file should be kept secure and NOT committed to Git

# Environment
ENVIRONMENT=production
DEBUG=False

# Application
SECRET_KEY=${SECRET_KEY}
APP_HOST=0.0.0.0
APP_PORT=8000
USE_HTTPS=True

# Security
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
CORS_ORIGINS=["https://www.fdx.trading", "https://fdx.trading"]
ALLOWED_HOSTS=["www.fdx.trading", "fdx.trading", "localhost"]

# Azure Database for PostgreSQL
DATABASE_URL=postgresql://${DB_USER}@${DB_HOST}:${DB_PASSWORD}@${DB_HOST}.postgres.database.azure.com:5432/${DB_NAME}?sslmode=require

# Azure Cache for Redis
REDIS_URL=rediss://:${REDIS_PASSWORD}@${REDIS_HOST}.redis.cache.windows.net:6380/0

# Azure OpenAI Services
AZURE_OPENAI_ENDPOINT=${AZURE_OPENAI_ENDPOINT}
AZURE_OPENAI_KEY=${AZURE_OPENAI_KEY}
AZURE_OPENAI_API_VERSION=2024-08-01-preview
AZURE_OPENAI_DEPLOYMENT_NAME=${AZURE_OPENAI_DEPLOYMENT_NAME}
AZURE_OPENAI_VISION_DEPLOYMENT=${AZURE_OPENAI_VISION_DEPLOYMENT}

# Azure Computer Vision
AZURE_VISION_ENDPOINT=${AZURE_VISION_ENDPOINT}
AZURE_VISION_KEY=${AZURE_VISION_KEY}

# Azure Document Intelligence
AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT=${AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT}
AZURE_DOCUMENT_INTELLIGENCE_KEY=${AZURE_DOCUMENT_INTELLIGENCE_KEY}

# Azure Cognitive Search
AZURE_SEARCH_ENDPOINT=${AZURE_SEARCH_ENDPOINT}
AZURE_SEARCH_KEY=${AZURE_SEARCH_KEY}
AZURE_SEARCH_INDEX=products

# Azure Storage
AZURE_STORAGE_CONNECTION_STRING=${AZURE_STORAGE_CONNECTION_STRING}
AZURE_STORAGE_CONTAINER=foodxchange-uploads

# Email Configuration
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USERNAME=apikey
SMTP_PASSWORD=${SENDGRID_API_KEY}
SMTP_FROM=noreply@fdx.trading

# Monitoring
SENTRY_DSN=${SENTRY_DSN}
LOG_LEVEL=INFO
LOG_FORMAT=json

# Application Insights
APPINSIGHTS_INSTRUMENTATIONKEY=${APPINSIGHTS_INSTRUMENTATIONKEY}

# Feature Flags
ENABLE_RATE_LIMITING=True
ENABLE_CACHING=True
ENABLE_ANALYTICS=True

# File Upload
MAX_UPLOAD_SIZE=10485760  # 10MB in bytes
ALLOWED_EXTENSIONS=jpg,jpeg,png,webp,pdf

# Rate Limiting
RATE_LIMIT_DEFAULT=60
RATE_LIMIT_WINDOW=3600

# Session
SESSION_LIFETIME=86400  # 24 hours in seconds
SESSION_SECURE=True  # HTTPS only

# Workers
WEB_WORKERS=4
WEB_THREADS=2
WORKER_CONNECTIONS=1000