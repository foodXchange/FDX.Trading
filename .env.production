# FoodXchange Production Environment Variables
# Following documentation requirements for simple, secure configuration

# Environment
DEBUG=False
ENVIRONMENT=production

# Security
SECRET_KEY=your-super-secret-production-key-change-this-immediately

# Database (Azure PostgreSQL)
DATABASE_URL=postgresql://foodxchange_user:your-password@foodxchange-flex-db.postgres.database.azure.com:5432/foodxchange
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=3600

# Azure Services
AZURE_STORAGE_CONNECTION_STRING=your-azure-storage-connection-string
AZURE_STORAGE_CONTAINER=foodxchange-documents
AZURE_VISION_ENDPOINT=your-azure-vision-endpoint
AZURE_VISION_KEY=your-azure-vision-key

# AI Services
OPENAI_API_KEY=your-openai-api-key

# Email (Simple SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@fdx.trading
SMTP_PASSWORD=your-app-password

# Performance Settings
WORKERS=4
MAX_CONNECTIONS=100

# Logging
LOG_LEVEL=INFO