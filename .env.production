# FoodXchange Production Environment Configuration
# Use least-privilege user for production

# Database Configuration - Production User
DATABASE_URL=postgresql://appuser:FoodX2024AppUser!@foodxchangepgfr.postgres.database.azure.com:5432/foodxchange?sslmode=require

# Security - Generate a strong secret key for production
SECRET_KEY=generate-a-new-secure-random-string-for-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Application Environment
ENVIRONMENT=production
DEBUG=False
USE_HTTPS=True

# Azure OpenAI Configuration (if needed)
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_DEPLOYMENT_NAME=

# Azure Storage Configuration (if needed)
AZURE_STORAGE_CONNECTION_STRING=

# Azure Email Configuration (if needed)
AZURE_EMAIL_CONNECTION_STRING=

# SMTP Email Configuration (if needed)
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=

# Redis Configuration (if needed)
REDIS_URL=