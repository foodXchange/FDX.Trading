# FoodXchange Environment Configuration
# Copy this file to .env.development, .env.staging, or .env.production
# and update with appropriate values

# Environment
ENVIRONMENT=development
DEBUG=True

# Database (PostgreSQL)
DATABASE_URL=postgresql://foodxchange:password@localhost:5432/foodxchange
DB_HOST=localhost
DB_PORT=5432
DB_NAME=foodxchange
DB_USER=foodxchange
DB_PASSWORD=password

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Application
SECRET_KEY=your-secret-key-here-change-in-production
APP_HOST=0.0.0.0
APP_PORT=8003
USE_HTTPS=False

# Security
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
CORS_ORIGINS=["http://localhost:3000", "http://localhost:8003"]
ALLOWED_HOSTS=["localhost", "127.0.0.1"]

# Azure OpenAI
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_KEY=your-api-key-here
AZURE_OPENAI_API_VERSION=2024-08-01-preview
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4
AZURE_OPENAI_VISION_DEPLOYMENT=gpt-4o

# Azure Computer Vision
AZURE_VISION_ENDPOINT=https://your-vision-resource.cognitiveservices.azure.com/
AZURE_VISION_KEY=your-vision-api-key

# Azure Document Intelligence
AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT=https://your-document-intelligence.cognitiveservices.azure.com/
AZURE_DOCUMENT_INTELLIGENCE_KEY=your-document-intelligence-key

# Azure Cognitive Search (Optional)
AZURE_SEARCH_ENDPOINT=https://your-search-service.search.windows.net
AZURE_SEARCH_KEY=your-search-api-key
AZURE_SEARCH_INDEX=products

# Azure Translator (Optional)
AZURE_TRANSLATOR_KEY=your-translator-key
AZURE_TRANSLATOR_ENDPOINT=https://api.cognitive.microsofttranslator.com
AZURE_TRANSLATOR_REGION=your-region

# Azure Storage (Optional)
AZURE_STORAGE_CONNECTION_STRING=your-storage-connection-string
AZURE_STORAGE_CONTAINER=product-images

# Email Configuration (Optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@foodxchange.com

# Monitoring (Optional)
SENTRY_DSN=
LOG_LEVEL=INFO
LOG_FORMAT=json

# Feature Flags
ENABLE_RATE_LIMITING=True
ENABLE_CACHING=True
ENABLE_ANALYTICS=True

# File Upload
MAX_UPLOAD_SIZE=10485760  # 10MB in bytes
ALLOWED_EXTENSIONS=jpg,jpeg,png,webp,pdf

# Rate Limiting
RATE_LIMIT_DEFAULT=100
RATE_LIMIT_WINDOW=3600

# Session
SESSION_LIFETIME=86400  # 24 hours in seconds
SESSION_SECURE=False  # Set to True in production with HTTPS

# Workers (for production)
WEB_CONCURRENCY=4
WORKER_CONNECTIONS=1000