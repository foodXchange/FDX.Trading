# FoodXchange Environment Configuration
# Copy this file to .env and fill in your actual values

# Application Settings
SECRET_KEY=your-secret-key-here
DATABASE_URL=sqlite:///./foodxchange.db
ENVIRONMENT=development
DEBUG=True

# Azure Computer Vision API
AZURE_VISION_ENDPOINT=https://your-vision-resource.cognitiveservices.azure.com/
AZURE_VISION_KEY=your-vision-api-key

# Azure OpenAI API
AZURE_OPENAI_API_KEY=your-openai-api-key
AZURE_OPENAI_ENDPOINT=https://your-openai-resource.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4

# Azure Cognitive Search (Optional)
AZURE_SEARCH_ENDPOINT=https://your-search-service.search.windows.net
AZURE_SEARCH_KEY=your-search-api-key
AZURE_SEARCH_INDEX=products

# Azure Storage (Optional)
AZURE_STORAGE_CONNECTION_STRING=your-storage-connection-string
AZURE_STORAGE_CONTAINER=product-images

# Email Configuration (Optional)
AZURE_EMAIL_CONNECTION_STRING=your-email-connection-string
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password