@page "/"
@using Microsoft.AspNetCore.Authorization
@using System.Net.Http.Json
@attribute [AllowAnonymous]
@layout PublicLayout
@inject HttpClient Http
@inject NavigationManager Navigation

<!-- Page Title: FDX.trading - Food Sourcing, Compliance & Trade Platform -->

<!-- Hero Section -->
<section class="py-5" style="background: linear-gradient(135deg, #f8f7f4 0%, #e8f5f3 100%);">
    <div class="container">
        <div class="row align-items-center py-5">
            <div class="col-lg-6 mb-4 mb-lg-0">
                <h1 class="display-4 fw-bold mb-4" style="color: #1f2937;">
                    Trade food products with confidence — from RFQ to delivery.
                </h1>
                <p class="lead mb-4" style="color: #374151;">
                    FDX.trading unifies sourcing, compliance (Kosher & QA), contracts, orders, shipments, and finance — so buyers and suppliers move faster together.
                </p>
                <div class="d-flex gap-3 mb-4">
                    <a href="/auth/login" class="btn btn-lg text-white" style="background-color: #006d77;">
                        <i class="bi bi-box-arrow-in-right me-2"></i>Sign in
                    </a>
                    <a href="#demo" class="btn btn-lg btn-outline-dark">
                        Request a demo
                    </a>
                </div>
                <div class="d-flex gap-4 text-muted small">
                    <span><i class="bi bi-check-circle-fill text-success"></i> Kosher-first workflows</span>
                    <span><i class="bi bi-check-circle-fill text-success"></i> Global logistics</span>
                    <span><i class="bi bi-check-circle-fill text-success"></i> Azure secure</span>
                </div>
            </div>
            <div class="col-lg-6">
                <div class="card shadow-lg border-0">
                    <div class="card-body p-4">
                        <h5 class="card-title mb-4">Your complete workflow</h5>
                        <ol class="list-unstyled">
                            @foreach (var step in workflowSteps)
                            {
                                <li class="d-flex align-items-start mb-3">
                                    <span class="badge rounded-pill me-3" style="background-color: #ff6f00; min-width: 30px;">@step.Number</span>
                                    <div>
                                        <strong>@step.Title</strong> — @step.Description
                                    </div>
                                </li>
                            }
                        </ol>
                        <div class="mt-4 p-3 bg-light rounded">
                            <small class="text-muted">
                                <i class="bi bi-shield-check me-2"></i>
                                Compliance gates ensure quality at every step
                            </small>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Features Section -->
<section id="features" class="py-5 bg-white">
    <div class="container">
        <div class="text-center mb-5">
            <h2 class="display-5 fw-bold">Built for modern food trade</h2>
            <p class="lead text-muted">Everything you need to source, certify, and ship food products globally</p>
        </div>
        <div class="row g-4">
            @foreach (var feature in features)
            {
                <div class="col-md-4">
                    <div class="card h-100 border-0 shadow-sm">
                        <div class="card-body p-4">
                            <div class="mb-3">
                                <i class="bi @feature.Icon fs-1" style="color: #006d77;"></i>
                            </div>
                            <h5 class="card-title" style="color: #006d77;">@feature.Title</h5>
                            <p class="card-text text-muted">@feature.Description</p>
                            <ul class="list-unstyled small">
                                @foreach (var item in feature.Items)
                                {
                                    <li class="mb-1"><i class="bi bi-check2 text-success"></i> @item</li>
                                }
                            </ul>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</section>

<!-- Security Section -->
<section id="security" class="py-5" style="background-color: #f8f7f4;">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-lg-6 mb-4 mb-lg-0">
                <h2 class="display-5 fw-bold mb-4">Enterprise security & compliance</h2>
                <div class="d-flex align-items-start mb-3">
                    <i class="bi bi-shield-lock-fill fs-4 me-3" style="color: #006d77;"></i>
                    <div>
                        <h6>Azure AD / Entra ID SSO</h6>
                        <p class="text-muted small">Single sign-on with your corporate identity provider</p>
                    </div>
                </div>
                <div class="d-flex align-items-start mb-3">
                    <i class="bi bi-database-lock fs-4 me-3" style="color: #006d77;"></i>
                    <div>
                        <h6>Azure SQL with encryption</h6>
                        <p class="text-muted small">Row-level security and audit logging for all transactions</p>
                    </div>
                </div>
                <div class="d-flex align-items-start mb-3">
                    <i class="bi bi-file-earmark-lock fs-4 me-3" style="color: #006d77;"></i>
                    <div>
                        <h6>Secure document storage</h6>
                        <p class="text-muted small">Azure Blob Storage with SAS tokens for evidence and certificates</p>
                    </div>
                </div>
                <div class="d-flex align-items-start">
                    <i class="bi bi-graph-up fs-4 me-3" style="color: #006d77;"></i>
                    <div>
                        <h6>Real-time observability</h6>
                        <p class="text-muted small">Application Insights for monitoring and performance</p>
                    </div>
                </div>
            </div>
            <div class="col-lg-6">
                <div class="card border-0 shadow-lg">
                    <div class="card-body p-4">
                        <h5 class="card-title mb-3">Compliance certifications</h5>
                        <div class="row g-3">
                            <div class="col-6">
                                <div class="text-center p-3 bg-light rounded">
                                    <i class="bi bi-patch-check-fill fs-1 text-success"></i>
                                    <div class="small mt-2">ISO 27001</div>
                                </div>
                            </div>
                            <div class="col-6">
                                <div class="text-center p-3 bg-light rounded">
                                    <i class="bi bi-patch-check-fill fs-1 text-success"></i>
                                    <div class="small mt-2">GDPR</div>
                                </div>
                            </div>
                            <div class="col-6">
                                <div class="text-center p-3 bg-light rounded">
                                    <i class="bi bi-patch-check-fill fs-1 text-success"></i>
                                    <div class="small mt-2">SOC 2</div>
                                </div>
                            </div>
                            <div class="col-6">
                                <div class="text-center p-3 bg-light rounded">
                                    <i class="bi bi-patch-check-fill fs-1 text-success"></i>
                                    <div class="small mt-2">HACCP</div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Demo Form Section -->
<section id="demo" class="py-5 bg-white">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-8">
                <div class="text-center mb-5">
                    <h2 class="display-5 fw-bold">Request a demo</h2>
                    <p class="lead text-muted">See how FDX can transform your food sourcing and trade operations</p>
                </div>
                <div class="card border-0 shadow-lg">
                    <div class="card-body p-5">
                        <EditForm Model="@lead" OnValidSubmit="SubmitLead">
                            <DataAnnotationsValidator />
                            <div class="row g-3">
                                <div class="col-md-6">
                                    <label class="form-label">Full name *</label>
                                    <InputText class="form-control form-control-lg" @bind-Value="@lead.Name" placeholder="John Smith" />
                                    <ValidationMessage For="@(() => lead.Name)" />
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label">Work email *</label>
                                    <InputText class="form-control form-control-lg" @bind-Value="@lead.Email" placeholder="john@company.com" />
                                    <ValidationMessage For="@(() => lead.Email)" />
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label">Company *</label>
                                    <InputText class="form-control form-control-lg" @bind-Value="@lead.Company" placeholder="Your company" />
                                    <ValidationMessage For="@(() => lead.Company)" />
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label">Phone</label>
                                    <InputText class="form-control form-control-lg" @bind-Value="@lead.Phone" placeholder="+1 234 567 8900" />
                                </div>
                                <div class="col-12">
                                    <label class="form-label">What are you looking to source?</label>
                                    <InputTextArea class="form-control form-control-lg" @bind-Value="@lead.Message" rows="3" 
                                                   placeholder="Tell us about your sourcing needs..." />
                                </div>
                                <!-- Honeypot field for bot protection -->
                                <div style="display: none;">
                                    <InputText @bind-Value="@lead.Website" />
                                </div>
                            </div>
                            <div class="mt-4">
                                <button type="submit" class="btn btn-lg text-white w-100" style="background-color: #ff6f00;" disabled="@isSubmitting">
                                    @if (isSubmitting)
                                    {
                                        <span class="spinner-border spinner-border-sm me-2"></span>
                                    }
                                    Send demo request
                                </button>
                            </div>
                        </EditForm>
                        @if (sent)
                        {
                            <div class="alert alert-success mt-3">
                                <i class="bi bi-check-circle-fill me-2"></i>
                                Thanks! We'll get back to you within 24 hours.
                            </div>
                        }
                        @if (error)
                        {
                            <div class="alert alert-danger mt-3">
                                <i class="bi bi-x-circle-fill me-2"></i>
                                Something went wrong. Please try again or email us at info@foodz-x.com
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- FAQ Section -->
<section id="faq" class="py-5" style="background-color: #f8f7f4;">
    <div class="container">
        <div class="text-center mb-5">
            <h2 class="display-5 fw-bold">Frequently asked questions</h2>
        </div>
        <div class="row justify-content-center">
            <div class="col-lg-8">
                <div class="accordion" id="faqAccordion">
                    @foreach (var (faq, index) in faqs.Select((f, i) => (f, i)))
                    {
                        <div class="accordion-item border-0 mb-3">
                            <h2 class="accordion-header">
                                <button class="accordion-button @(index > 0 ? "collapsed" : "")" type="button" 
                                        data-bs-toggle="collapse" data-bs-target="#faq-@index">
                                    @faq.Question
                                </button>
                            </h2>
                            <div id="faq-@index" class="accordion-collapse collapse @(index == 0 ? "show" : "")" 
                                 data-bs-parent="#faqAccordion">
                                <div class="accordion-body">
                                    @faq.Answer
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</section>

<!-- CTA Section -->
<section class="py-5 text-white" style="background-color: #006d77;">
    <div class="container text-center">
        <h2 class="display-5 fw-bold mb-4">Ready to streamline your food trade?</h2>
        <p class="lead mb-4">Join leading food companies already using FDX</p>
        <div class="d-flex gap-3 justify-content-center">
            <a href="/auth/login" class="btn btn-light btn-lg">
                <i class="bi bi-box-arrow-in-right me-2"></i>Sign in
            </a>
            <a href="#demo" class="btn btn-outline-light btn-lg">
                Get started
            </a>
        </div>
    </div>
</section>

@code {
    private MarketingLead lead = new();
    private bool sent = false;
    private bool error = false;
    private bool isSubmitting = false;

    private List<WorkflowStep> workflowSteps = new()
    {
        new("1", "RFQ", "Create request & line items"),
        new("2", "Proposals", "Compare 1-5 best suppliers"),
        new("3", "Compliance", "Kosher, QA, Labeling checklists"),
        new("4", "Contract", "Lock price & quantities"),
        new("5", "Order", "Assign import manager, place PO"),
        new("6", "Shipments", "Containers, milestones, docs"),
        new("7", "Finance", "Commissions & invoices")
    };

    private List<Feature> features = new()
    {
        new Feature(
            "bi-search",
            "Smart Sourcing",
            "AI-powered supplier matching based on your requirements",
            new[] { "95% capability match", "Brand compatibility", "Compliance pre-check" }
        ),
        new Feature(
            "bi-shield-check",
            "Full Compliance",
            "End-to-end compliance tracking with evidence management",
            new[] { "Kosher certification", "QA testing", "Label approval", "Audit trails" }
        ),
        new Feature(
            "bi-globe",
            "Global Logistics",
            "Complete shipment tracking from origin to destination",
            new[] { "Container tracking", "Document management", "Milestone alerts" }
        ),
        new Feature(
            "bi-currency-dollar",
            "Automated Finance",
            "Commission calculation and invoice generation",
            new[] { "Auto-accrual", "AR/AP tracking", "Payment reconciliation" }
        ),
        new Feature(
            "bi-people",
            "Collaboration Hub",
            "Connect buyers, suppliers, and external experts",
            new[] { "Role-based access", "Project consoles", "Real-time updates" }
        ),
        new Feature(
            "bi-graph-up",
            "Analytics & Insights",
            "Data-driven decisions with real-time dashboards",
            new[] { "Performance metrics", "Supplier ratings", "Trend analysis" }
        )
    };

    private List<FAQ> faqs = new()
    {
        new("Do suppliers need an account?", 
            "Yes — suppliers and external experts get portal access scoped to their projects. They can submit proposals, upload compliance documents, and track shipments."),
        new("Is Kosher certification supported?", 
            "Yes — authority selection, certificates, Passover status, and labeling marks are all built-in. We support OK, OU, Badatz, and other major certifiers."),
        new("How does the compliance gate work?", 
            "Orders can only be created after all compliance stages are 100% approved. This ensures quality and regulatory requirements are met before any commitment."),
        new("What about existing ERP integration?", 
            "FDX provides REST APIs and webhook notifications to integrate with SAP, Oracle, NetSuite, and other ERPs. We also support CSV import/export."),
        new("Is this suitable for small businesses?", 
            "Yes — FDX scales from small importers doing 10 orders/year to large enterprises with thousands of SKUs. Our pricing is usage-based."),
        new("What regions are supported?", 
            "We support global trade with special focus on Israel, EU, and US markets. Multi-currency, multi-language, and local compliance rules are included.")
    };

    private async Task SubmitLead()
    {
        // Bot protection - honeypot check
        if (!string.IsNullOrEmpty(lead.Website))
        {
            sent = true; // Fake success for bots
            return;
        }

        try
        {
            isSubmitting = true;
            error = false;
            
            lead.Source = "homepage";
            var response = await Http.PostAsJsonAsync("/api/marketing/leads", lead);
            
            if (response.IsSuccessStatusCode)
            {
                sent = true;
                lead = new(); // Reset form
            }
            else
            {
                error = true;
            }
        }
        catch
        {
            error = true;
        }
        finally
        {
            isSubmitting = false;
        }
    }

    public class MarketingLead
    {
        [Required(ErrorMessage = "Name is required")]
        public string Name { get; set; } = "";
        
        [Required(ErrorMessage = "Email is required")]
        [EmailAddress(ErrorMessage = "Invalid email address")]
        public string Email { get; set; } = "";
        
        [Required(ErrorMessage = "Company is required")]
        public string Company { get; set; } = "";
        
        public string? Phone { get; set; }
        public string? Message { get; set; }
        public string? Source { get; set; }
        public string? Website { get; set; } // Honeypot field
    }

    record WorkflowStep(string Number, string Title, string Description);
    record Feature(string Icon, string Title, string Description, string[] Items);
    record FAQ(string Question, string Answer);
}