# FoodXchange Environment Configuration Template
# Copy this file to .env and replace the placeholder values

# Azure PostgreSQL Database Configuration
DATABASE_URL=postgresql://USERNAME:PASSWORD@SERVER.postgres.database.azure.com:5432/DATABASE_NAME?sslmode=require

# Server Configuration Example:
# Server: fdx-postgres-server.postgres.database.azure.com
# Database: foodxchange
# Admin: fdxadmin
# Password: [REPLACE_WITH_ACTUAL_PASSWORD]

# App Configuration
APP_NAME=FoodXchange
DEBUG=False
APP_ENV=production

# Azure OpenAI Configuration
AZURE_OPENAI_KEY=REPLACE_WITH_ACTUAL_KEY
AZURE_OPENAI_ENDPOINT=https://YOUR_RESOURCE.cognitiveservices.azure.com/
AZURE_OPENAI_DEPLOYMENT=YOUR_DEPLOYMENT_NAME

# Azure Storage (for backups - optional)
AZURE_STORAGE_ACCOUNT=REPLACE_WITH_STORAGE_ACCOUNT
AZURE_STORAGE_KEY=REPLACE_WITH_STORAGE_KEY
AZURE_STORAGE_CONTAINER=backups

# Security Settings
SECRET_KEY=REPLACE_WITH_RANDOM_SECRET_KEY
JWT_SECRET=REPLACE_WITH_JWT_SECRET

# Email Configuration (optional)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=REPLACE_WITH_APP_PASSWORD

# Monitoring (optional)
SENTRY_DSN=https://YOUR_SENTRY_DSN
LOGGING_LEVEL=INFO