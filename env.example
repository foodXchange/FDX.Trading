# FoodXchange Platform Environment Configuration
# Copy this file to .env and update with your actual values

# =============================================================================
# CRITICAL SECURITY SETTINGS (REQUIRED)
# =============================================================================

# Secret key for JWT tokens and session encryption
# Generate a secure key: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your-super-secret-key-change-this-immediately

# Environment (development, staging, production)
ENVIRONMENT=development

# Debug mode (set to false in production)
DEBUG=false

# Use HTTPS (set to true in production)
USE_HTTPS=false

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================

# Database URL (Azure PostgreSQL)
DATABASE_URL=postgresql://username:password@host:port/database
# DATABASE_URL=postgresql://username:password@localhost:5432/foodxchange

# =============================================================================
# AZURE SERVICES CONFIGURATION (OPTIONAL)
# =============================================================================

# Azure OpenAI
AZURE_OPENAI_API_KEY=your-azure-openai-api-key
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT_NAME=your-deployment-name

# Azure Computer Vision
AZURE_VISION_ENDPOINT=https://your-resource.cognitiveservices.azure.com/
AZURE_VISION_KEY=your-vision-api-key

# Azure Cognitive Search
AZURE_SEARCH_ENDPOINT=https://your-search-service.search.windows.net
AZURE_SEARCH_KEY=your-search-api-key
AZURE_SEARCH_INDEX=products

# Azure Storage
AZURE_STORAGE_CONNECTION_STRING=your-storage-connection-string
AZURE_STORAGE_CONTAINER=product-images

# Azure Communication Services
AZURE_EMAIL_CONNECTION_STRING=your-email-connection-string

# Azure Translator
AZURE_TRANSLATOR_KEY=your-translator-api-key

# =============================================================================
# EMAIL CONFIGURATION (OPTIONAL)
# =============================================================================

# SMTP Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# =============================================================================
# CACHING AND SESSIONS
# =============================================================================

# Redis URL (optional, for caching and rate limiting)
REDIS_URL=redis://localhost:6379

# =============================================================================
# MONITORING AND LOGGING
# =============================================================================

# Sentry DSN for error tracking
SENTRY_DSN=your-sentry-dsn

# Logging configuration
LOG_LEVEL=INFO
LOG_FILE=logs/foodxchange.log
STRUCTURED_LOGGING=true

# =============================================================================
# SECURITY HEADERS AND CORS
# =============================================================================

# Allowed CORS origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000,https://yourdomain.com

# Rate limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_DEFAULT=100
RATE_LIMIT_WINDOW=3600

# =============================================================================
# FILE UPLOAD CONFIGURATION
# =============================================================================

# Maximum file upload size (in bytes)
MAX_FILE_SIZE=10485760

# Allowed file types (comma-separated)
ALLOWED_FILE_TYPES=.jpg,.jpeg,.png,.gif,.pdf,.doc,.docx,.txt,.csv

# =============================================================================
# THIRD-PARTY INTEGRATIONS (OPTIONAL)
# =============================================================================

# Supabase (alternative to Azure)
SUPABASE_URL=your-supabase-url
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# =============================================================================
# DEVELOPMENT SETTINGS
# =============================================================================

# Auto-reload (development only)
AUTO_RELOAD=true

# Database echo (SQL logging)
DB_ECHO=false

# =============================================================================
# PRODUCTION SETTINGS
# =============================================================================

# Worker processes
WORKERS=4

# Bind address
BIND_ADDRESS=0.0.0.0

# Port
PORT=8000

# =============================================================================
# SECURITY CHECKLIST
# =============================================================================
# Before deploying to production, ensure:
# 1. SECRET_KEY is changed to a secure random value
# 2. DEBUG=false
# 3. USE_HTTPS=true
# 4. All API keys are properly secured
# 5. Database uses strong authentication
# 6. CORS origins are restricted to your domains
# 7. Rate limiting is enabled
# 8. File upload restrictions are in place
# 9. Logging is configured for security monitoring
# 10. All dependencies are up to date 